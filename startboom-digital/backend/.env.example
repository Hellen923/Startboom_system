# MongoDB Configuration - STARTBOOM DIGITAL
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/startboom_sales_db?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=startboom_digital_secret_key_2026_sales_system_v1

# Server Configuration
PORT=5000
NODE_ENV=development

# Email Configuration (Nodemailer) - UPDATE WITH STARTBOOM CREDENTIALS
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@startboomdigital.com
EMAIL_PASS=your_app_specific_password
EMAIL_FROM=notifications@startboomdigital.com
EMAIL_CONNECTION_TIMEOUT=30000
EMAIL_GREETING_TIMEOUT=30000
EMAIL_SOCKET_TIMEOUT=60000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://startboom-digital.vercel.app

# Twilio (Optional - for SMS/Voice)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number

# OpenStreetMap Nominatim (for Uganda location search)
NOMINATIM_USER_AGENT=StartboomDigitalSalesApp/1.0
