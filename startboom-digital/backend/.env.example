# HoneyPot CRM - Backend Environment Variables
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/honeypot_crm_db?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_strong_jwt_secret_here

# Server
PORT=5000
NODE_ENV=development

# Gmail (use a Google App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=your_email@gmail.com

# App URLs
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# OpenStreetMap
NOMINATIM_USER_AGENT=HoneyPotCRM/1.0
